---
import { SITE } from '../consts';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="CV"
  description="View the CV of Duo Sun, including education, experience, core skills, and contact details."
  activePath="/cv"
>
  <section class="page-header">
    <p class="eyebrow">Curriculum Vitae</p>
    <h1 class="page-title page-title--compact">Education, experience, and core skills</h1>
    <p class="page-lead">
      A concise professional summary designed for recruiters, collaborators, and
      academic contacts who want a quick picture of my background.
    </p>
  </section>

  <section class="section cv-download-section">
    <article class="surface">
      <p class="eyebrow">Download</p>
      <h2 class="card-title">Formal PDF version</h2>
      <p>
        Use the PDF version when you want a cleaner file for recruiters,
        applications, referrals, or direct sharing.
      </p>
      <div class="button-row">
        <a class="button" href={SITE.cvPdfPath} download>Download PDF</a>
      </div>
      <p class="meta">CV last updated: {SITE.cvLastUpdated}</p>
    </article>
  </section>

  <section class="split">
    <div class="stack">
      <article class="surface">
        <p class="eyebrow">Experience</p>
        <h2 class="card-title">Professional work</h2>

        <div class="timeline">
          <div class="timeline__item">
            <h3>Intern, CITIC Securities</h3>
            <p class="meta">Finance-related materials, research support, and analytical work</p>
            <ul class="detail-list">
              <li>Supported finance-oriented research and background preparation.</li>
              <li>Worked with structured materials, summaries, and internal analysis tasks.</li>
              <li>Built familiarity with professional expectations in a finance environment.</li>
            </ul>
          </div>
        </div>
      </article>

      <article class="surface">
        <p class="eyebrow">Education</p>
        <h2 class="card-title">Academic profile</h2>

        <div class="timeline">
          <div class="timeline__item">
            <h3>University of Manchester</h3>
            <p class="meta">BSc Economics</p>
            <p>
              Formal training in economics, analytical reasoning, and the study
              of markets, institutions, and decision-making.
            </p>
          </div>
        </div>
      </article>
    </div>

    <aside class="stack">
      <section class="surface">
        <p class="eyebrow">Profile</p>
        <h2 class="card-title">Summary</h2>
        <p>
          Economics student with interests spanning finance, technology,
          research, and communication. Comfortable moving between structured
          analysis and clear written presentation.
        </p>
      </section>

      <section class="surface">
        <p class="eyebrow">Skills</p>
        <h2 class="card-title">Core tools</h2>
        <ul class="chip-list">
          <li class="chip">Excel</li>
          <li class="chip">SPSS</li>
          <li class="chip">Research</li>
          <li class="chip">Data analysis</li>
          <li class="chip">Writing</li>
          <li class="chip">Presentation</li>
        </ul>
      </section>

      <section class="surface">
        <p class="eyebrow">Contact</p>
        <h2 class="card-title">Reach me</h2>
        <p>{SITE.email}</p>
        <p>{SITE.phoneDisplay}</p>
        <p>{SITE.location}</p>
      </section>
    </aside>
  </section>
</Layout>

<style>
  .cv-download-section {
    margin-bottom: 2.4rem;
  }

  @media (max-width: 900px) {
    .cv-download-section {
      margin-bottom: 1.8rem;
    }
  }
</style>
