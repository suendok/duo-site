---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = await getCollection('posts');
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-GB', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<Layout
  title="Posts"
  description="Static notes and writing by Duo Sun."
  activePath="/posts"
>
  <section class="page-header">
    <p class="eyebrow">Posts</p>
    <h1 class="page-title page-title--compact">Writing and working notes</h1>
    <p class="page-lead">
      A small collection of static Markdown posts. No CMS, no database, and no
      server-side logic, just simple content that ships with the site.
    </p>
  </section>

  {posts.length === 0 ? (
    <article class="surface">
      <p class="eyebrow">No Posts Yet</p>
      <h2 class="card-title">The structure is ready</h2>
      <p>
        Add Markdown files to <code>src/content/posts</code> and they will
        appear here automatically at build time.
      </p>
    </article>
  ) : (
    <section class="post-list">
      {posts.map((post) => (
        <a class="surface link-card" href={`/posts/${post.id}/`}>
          <p class="eyebrow">Post</p>
          <h2 class="card-title">{post.data.title}</h2>
          <p class="meta">{formatDate(post.data.date)}</p>
          <p>{post.data.description}</p>
        </a>
      ))}
    </section>
  )}
</Layout>
