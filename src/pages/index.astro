---
const name = "Duo Sun";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{name}</title>
    <style>
      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, sans-serif;
        background: #f7f7f5;
        color: #111;
        line-height: 1.6;
      }

      .container {
        max-width: 900px;
        margin: 0 auto;
        padding: 40px 20px;
      }

      nav a {
        margin-right: 16px;
      }

      h1 {
        font-size: 48px;
        margin-bottom: 10px;
      }

      p {
        color: #555;
        font-size: 18px;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
        <a href="/posts">Posts</a>
        <a href="/contact">Contact</a>
      </nav>

      <h1>Hi, I'm Duo Sun</h1>
      <p>
        Economics student in the UK. I write about finance, technology, and
        personal thinking.
      </p>
    </div>
  </body>
</html>