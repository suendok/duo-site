---
import { SITE } from '../consts';

interface Props {
  title?: string;
  description?: string;
  activePath?: string;
  wide?: boolean;
}

const {
  title = SITE.title,
  description = SITE.description,
  activePath = Astro.url.pathname,
  wide = false,
} = Astro.props;

const pageTitle = title === SITE.title ? SITE.title : `${title} | ${SITE.name}`;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/cv', label: 'CV' },
  { href: '/posts', label: 'Posts' },
  { href: '/contact', label: 'Contact' },
];

const isActive = (href: string) =>
  href === '/'
    ? activePath === href
    : activePath === href || activePath.startsWith(`${href}/`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="site-header__inner">
          <a class="brand" href="/">
            <span class="brand__title">{SITE.name}</span>
            <span class="brand__subtitle">Economics, research, finance, and writing</span>
          </a>

          <nav class="nav" aria-label="Main navigation">
            {navLinks.map((link) => (
              <a
                class:list={['nav__link', isActive(link.href) && 'is-active']}
                href={link.href}
              >
                {link.label}
              </a>
            ))}
          </nav>
        </div>
      </header>

      <main class:list={['site-main', wide && 'site-main--wide']}>
        <slot />
      </main>

      <footer class="site-footer">
        <div class="site-footer__inner">
          <p>{SITE.name}</p>
          <p>Built as a static Astro site for Cloudflare Pages.</p>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f4efe7;
    --bg-soft: rgba(255, 252, 248, 0.78);
    --panel: rgba(255, 255, 255, 0.7);
    --panel-strong: #fbf8f2;
    --accent: #17324d;
    --accent-soft: #d9e5ef;
    --ink: #1d1b18;
    --muted: #655e58;
    --border: rgba(23, 50, 77, 0.12);
    --shadow: 0 18px 60px rgba(23, 38, 54, 0.08);
    --radius-lg: 28px;
    --radius-md: 20px;
    --max: 960px;
    --max-wide: 1160px;
    --font-sans: 'Avenir Next', 'Segoe UI', sans-serif;
    --font-serif: 'Iowan Old Style', 'Palatino Linotype', 'Book Antiqua', Georgia, serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background: var(--bg);
  }

  body {
    margin: 0;
    min-height: 100vh;
    color: var(--ink);
    font-family: var(--font-sans);
    background:
      radial-gradient(circle at top left, rgba(228, 213, 188, 0.7), transparent 34%),
      radial-gradient(circle at top right, rgba(210, 226, 238, 0.8), transparent 28%),
      linear-gradient(180deg, #f7f2eb 0%, #f4efe7 45%, #f7f3ed 100%);
  }

  a {
    color: inherit;
  }

  p,
  li {
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.75;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    color: var(--ink);
    font-family: var(--font-serif);
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  ul {
    margin: 0;
    padding-left: 1.15rem;
  }

  code {
    padding: 0.15rem 0.4rem;
    border-radius: 0.45rem;
    background: rgba(23, 50, 77, 0.08);
    font-size: 0.92em;
  }

  .site-shell {
    min-height: 100vh;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(16px);
    background: linear-gradient(180deg, rgba(247, 242, 235, 0.92), rgba(247, 242, 235, 0.7));
    border-bottom: 1px solid rgba(23, 50, 77, 0.08);
  }

  .site-header__inner,
  .site-footer__inner {
    max-width: var(--max-wide);
    margin: 0 auto;
    padding: 1.1rem 1.5rem;
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    gap: 0.15rem;
    text-decoration: none;
  }

  .brand__title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--ink);
  }

  .brand__subtitle {
    color: var(--muted);
    font-size: 0.88rem;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .nav__link {
    padding: 0.7rem 1rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    color: var(--muted);
    transition:
      transform 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .nav__link:hover {
    transform: translateY(-1px);
    background: rgba(255, 255, 255, 0.78);
    color: var(--ink);
  }

  .nav__link.is-active {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .site-main {
    max-width: var(--max);
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }

  .site-main--wide {
    max-width: var(--max-wide);
  }

  .site-footer {
    padding-bottom: 1rem;
  }

  .site-footer__inner {
    border-top: 1px solid rgba(23, 50, 77, 0.08);
  }

  .site-footer__inner p {
    margin: 0;
    font-size: 0.95rem;
  }

  .eyebrow {
    margin: 0 0 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.8rem;
    color: var(--accent);
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: clamp(2.8rem, 8vw, 5.1rem);
    line-height: 0.96;
    margin-bottom: 1rem;
  }

  .page-title--compact {
    font-size: clamp(2.4rem, 7vw, 4rem);
  }

  .page-lead {
    max-width: 44rem;
    margin: 0;
    color: var(--muted);
    font-size: 1.18rem;
    line-height: 1.8;
  }

  .section {
    margin-top: 1.4rem;
  }

  .section-heading {
    display: flex;
    gap: 1rem;
    align-items: end;
    justify-content: space-between;
    margin-bottom: 1.2rem;
  }

  .section-heading p {
    max-width: 38rem;
    margin: 0;
  }

  .hero,
  .split,
  .grid {
    display: grid;
    gap: 1.25rem;
  }

  .hero {
    grid-template-columns: minmax(0, 1.35fr) minmax(280px, 0.8fr);
    align-items: stretch;
    margin-bottom: 1.5rem;
  }

  .split,
  .grid--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .grid--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .stack {
    display: grid;
    gap: 1.25rem;
  }

  .surface {
    padding: 1.6rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    background: var(--panel);
    box-shadow: var(--shadow);
  }

  .surface--accent {
    background: linear-gradient(160deg, #18314a 0%, #274e70 100%);
    color: rgba(255, 255, 255, 0.92);
  }

  .surface--accent h2,
  .surface--accent h3,
  .surface--accent p,
  .surface--accent li,
  .surface--accent .eyebrow,
  .surface--accent .meta {
    color: inherit;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.8rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.82rem 1.15rem;
    border-radius: 999px;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: white;
    font-weight: 500;
    text-decoration: none;
    transition:
      transform 160ms ease,
      background 160ms ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button--secondary {
    background: transparent;
    color: var(--accent);
  }

  .link-card {
    display: block;
    text-decoration: none;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .link-card:hover {
    transform: translateY(-2px);
    border-color: rgba(23, 50, 77, 0.22);
    background: rgba(255, 255, 255, 0.82);
  }

  .card-title {
    margin-bottom: 0.6rem;
    font-size: 1.5rem;
  }

  .meta {
    color: var(--muted);
    font-size: 0.92rem;
  }

  .stat-list,
  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding: 0;
    list-style: none;
  }

  .stat-list li,
  .chip-list li {
    margin: 0;
  }

  .stat {
    min-width: 9rem;
    padding: 0.9rem 1rem;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.14);
  }

  .surface .stat {
    background: rgba(23, 50, 77, 0.05);
    border-color: rgba(23, 50, 77, 0.08);
  }

  .stat strong,
  .chip {
    display: block;
    color: var(--ink);
  }

  .surface--accent .stat strong {
    color: white;
  }

  .chip {
    padding: 0.72rem 0.95rem;
    border-radius: 999px;
    background: rgba(23, 50, 77, 0.06);
    border: 1px solid rgba(23, 50, 77, 0.08);
    font-size: 0.96rem;
  }

  .fact-list {
    display: grid;
    gap: 1rem;
  }

  .fact-list div {
    padding-top: 1rem;
    border-top: 1px solid rgba(23, 50, 77, 0.08);
  }

  .fact-list div:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .fact-list dt {
    margin-bottom: 0.35rem;
    color: var(--ink);
    font-weight: 600;
  }

  .fact-list dd {
    margin: 0;
    color: var(--muted);
  }

  .timeline {
    display: grid;
    gap: 1rem;
  }

  .timeline__item {
    padding: 1.15rem 0 0;
    border-top: 1px solid rgba(23, 50, 77, 0.08);
  }

  .timeline__item:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .timeline__item h3 {
    font-size: 1.25rem;
    margin-bottom: 0.3rem;
  }

  .detail-list {
    margin-top: 0.8rem;
  }

  .detail-list li + li {
    margin-top: 0.35rem;
  }

  .post-list {
    display: grid;
    gap: 1rem;
  }

  .meta-link {
    display: inline-flex;
    margin-bottom: 1rem;
    color: var(--accent);
    text-decoration: none;
  }

  .prose {
    padding: 2rem;
    background: var(--panel-strong);
  }

  .prose > :first-child {
    margin-top: 0;
  }

  .prose > :last-child {
    margin-bottom: 0;
  }

  .prose h2,
  .prose h3 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.8rem;
  }

  .prose p,
  .prose li {
    font-size: 1.06rem;
  }

  @media (max-width: 900px) {
    .site-header__inner,
    .site-footer__inner,
    .section-heading {
      flex-direction: column;
      align-items: flex-start;
    }

    .hero,
    .split,
    .grid--2,
    .grid--3 {
      grid-template-columns: 1fr;
    }

    .site-main {
      padding-top: 1.75rem;
    }

    .surface,
    .prose {
      padding: 1.3rem;
    }
  }
</style>
